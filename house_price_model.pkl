   ],
   "source": [
    "# Pairplots of key features with the target\n",
    "selected_features = ['MedInc', 'HouseAge', 'AveRooms', 'AveBedrms', 'Population', 'AveOccup']\n",
    "sns.pairplot(df, x_vars=selected_features, y_vars='MedHouseVal', height=4, aspect=0.8, kind='scatter')\n",
    "plt.suptitle(\"Feature vs Target Relationships\", y=1.02)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
