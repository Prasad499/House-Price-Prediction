   "source": [
    "# Adding derived features\n",
    "df['rooms_per_population'] = df['AveRooms'] / df['Population']  # Rooms per person\n",
    "df['bedrooms_per_room'] = df['AveBedrms'] / df['AveRooms']      # Ratio of bedrooms to rooms\n",
    "df['population_per_occupant'] = df['Population'] / df['AveOccup']  # Population per occupant\n",
    "\n",
    "# Verify the new features\n",
    "print(df[['rooms_per_population', 'bedrooms_per_room', 'population_per_occupant']].head())"
   ]
  },
