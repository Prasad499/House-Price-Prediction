import streamlit as st
import joblib
import numpy as np

# Load the trained model
rf_model = joblib.load("house_price_model.pkl")

st.title("California Housing Price Predictor")

# Input features
med_inc = st.number_input("Median Income", value=3.5, key="med_inc")
house_age = st.number_input("House Age", value=20, key="house_age")
ave_rooms = st.number_input("Average Rooms", value=5, key="ave_rooms")
ave_bedrooms = st.number_input("Average Bedrooms", value=1, key="ave_bedrooms")
population = st.number_input("Population", value=1000, key="population")
ave_occup = st.number_input("Average Occupancy", value=3, key="ave_occup")
latitude = st.number_input("Latitude", value=34.0, key="latitude")
longitude = st.number_input("Longitude", value=-118.0, key="longitude")

# Derived features
rooms_per_population = ave_rooms / population if population != 0 else 0
bedrooms_per_room = ave_bedrooms / ave_rooms if ave_rooms != 0 else 0
population_per_occupant = population / ave_occup if ave_occup != 0 else 0

# Ensure input data matches the training feature set
if st.button("Predict"):
    input_data = np.array([[med_inc, house_age, ave_rooms, ave_bedrooms, population, ave_occup, latitude, longitude,
                            rooms_per_population, bedrooms_per_room, population_per_occupant]])
    predicted_price = rf_model.predict(input_data)[0]
    st.write(f"Predicted Median House Value: ${predicted_price * 100000:.2f}")
